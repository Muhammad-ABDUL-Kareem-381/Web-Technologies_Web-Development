@model List<SEF23_Web_HW_04.Models.FeedBack>
@{
    // Set the page title for the browser tab
    ViewData["Title"] = "All Feedbacks";
}

@* Display all feedbacks in a table *@
<html>
    <head>
        @* Head section can be used for additional styles or scripts if needed *@
    </head>
    <body>
        @* Page heading *@
        <h2> All Feedbacks </h2>

        @* Show message if there are no feedbacks *@
        @if(Model.Count() == 0)
        {
            <p class="fw-bold text-center">
                No feedbacks available.
            </p>
        }
        else
        {
            @* Table to display all feedback entries *@
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th> Id </th>
                        <th> StudentName </th>
                        <th> Course </th>
                        <th> Comments </th>
                        <th> Rating </th>
                        <th> DateTime</th>
                    </tr>
                </thead>
                <tbody>
                    @* Loop through each feedback and display its details in a row *@
                    @foreach(var feedback in Model)
                    {
                        <tr>
                            <td> @feedback.Id </td>
                            <td> @feedback.StudentName </td>
                            <td> @feedback.Course </td>
                            <td> @feedback.Comments </td>
                            <td> @feedback.Rating </td>
                            <td> @feedback.DateSubmitted </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        @* Button to return to the home/index page *@
    <a class="btn btn-primary" asp-controller="FeedBack" asp-action="Index"> Return </a>
    </body>
</html>