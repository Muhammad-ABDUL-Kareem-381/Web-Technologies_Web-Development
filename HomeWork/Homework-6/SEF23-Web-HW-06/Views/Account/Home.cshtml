@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class=" container mt-5">
    @if (ViewBag.UserEmail != null)
    {
        <div class="alert alert-info d-flex justify-content-center">
            <p >Welcome back @ViewBag.UserEmail! </p>
        </div>
    }
    else
    {
        <div class="alert alert-warning d-flex justify-content-center">
            <p class=" d-flex text-center">You are not logged in. Please <a asp-controller="Account" asp-action="Login">login</a> to continue. </p>
        </div>
    }
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Shop" asp-action="ProductList" class="btn btn-success mt-3">Go to Shop</a>
        <a asp-controller="Account" asp-action="Logout"  class="btn btn-danger mt-3">Logout</a>
    </div>
</div>