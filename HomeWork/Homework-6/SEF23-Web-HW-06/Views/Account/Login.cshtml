@model SEF23_Web_HW_06.Models.Entities.Account

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center min-vh-100 bg-light">
    <div class="card shadow-lg p-3 p-md-4" style="max-width: 400px; width: 100%">
        <h3 class="text-center mb-4 text-primary"> Darez Mart </h3>
        <h5 class="text-center mb-4">Login</h5>
        <form asp-controller="Account" method="post">

            <div class="mb-3">
                <label>Email address</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" type="email" required />
            </div>

            <div class="mb-3">
                <label >Password</label>
                <input asp-for="Password" class="form-control" placeholder="Enter password" type="password" required/>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input"/>
                    <label class="form-check-label">Remember me</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>
    </div>
</div>