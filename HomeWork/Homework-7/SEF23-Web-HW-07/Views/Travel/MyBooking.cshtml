@model List<SEF23_Web_HW_07.Models.Entities.BookingWithPackage>
@{
    ViewData["Title"] = "My Bookings";
    Layout = "_Layout";
}

<div class="container mt-3">
    <h2 class="text-center fw-bold">My Bookings</h2>
    @if (Model.Count() == 0)
    {
        <div class="alert alert-danger text-center">
            <h3>No booking found</h3>
            <p>You Haven't make any booking yet</p>
        </div>
        <div class="d-flex justify-content-center">
            <a class="btn btn-primary" asp-controller="Travel" asp-action="Index">Explore Packages</a>
        </div>
    }
    else
    {
        <div class="alert alert-success text-center">
            <h3>Booking Found</h3>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Booking ID</th>
                        <th>Package</th>
                        <th>Destination</th>
                        <th>Customer Name</th>
                        <th>Customer Email</th>
                        <th>Travelers</th>
                        <th>Total Amount</th>
                        <th>Booking Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td>@booking.BookingId</td>
                            <td>@booking.PackageName</td>
                            <td>@booking.Destination</td>
                            <td>@booking.CustomerName</td>
                            <td>@booking.CustomerEmail</td>
                            <td>@booking.NumberOfTravelers</td>
                            <td>Rs.@booking.TotalAmount</td>
                            <td>@booking.BookingDate.ToShortDateString()</td>
                            <td>@booking.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="mt-3 text-center fw-bolder">
            <strong>Total Bookings: @Model.Count</strong>
        </div>
        <div class="text-center">
            <a class="btn btn-primary" asp-controller="Travel" asp-action="Index">Explore More Packages</a>
        </div>
    }
</div>
