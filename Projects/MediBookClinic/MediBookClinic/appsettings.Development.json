{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Information"
    }
  },

  "DetailedErrors": true,

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=aspnet-MediBookClinic;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "EmailSettings": {
    "SmtpServer": "smtp.mailtrap.io",
    "SmtpPort": 2525,
    "SenderEmail": "dev@medibookclinic.local",
    "SenderName": "MediBook Clinic (DEV)",
    "Username": "your-mailtrap-username",
    "Password": "your-mailtrap-password",
    "EnableSsl": true
  },

  "SystemSettings": {
    "ApplicationName": "MediBook Clinic (DEVELOPMENT)",
    "MaintenanceMode": false,
    "EnableSignalRNotifications": true,
    "EnableEmailNotifications": false,
    "EnableSmsNotifications": false
  },

  "SecuritySettings": {
    "RequireEmailConfirmation": false,
    "RequirePhoneConfirmation": false,
    "EnableTwoFactorAuthentication": false
  }
}